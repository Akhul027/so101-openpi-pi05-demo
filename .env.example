# Laptop robot client
SO101_SERVER_URL=http://<RTX_SERVER_IP>:8000/predict
SO101_PORT=COM3
SO101_TOP_CAM=2
SO101_WRIST_CAM=3
SO101_TASK=move red cube to the brown area
SO101_LOOP_HZ=10
SO101_MAX_STEP_DEG=5
SO101_MAX_SHOULDER_LIFT_STEP_DEG=3
SO101_MAX_GRIPPER_STEP=12
SO101_STEPS=600
NO_PROXY=<RTX_SERVER_IP>,localhost,127.0.0.1

# RTX server
PI05_MODEL_PATH=/data/robot_project/models/pi05_v2model/pretrained_model
PI05_DEVICE=cuda
PI05_N_ACTION_STEPS=10
PI05_LOAD_ON_STARTUP=1

# Optional deploy tools. Never commit real values.
RTX_HOST=<RTX_SERVER_IP>
RTX_USER=<RTX_USERNAME>
RTX_PASSWORD=<RTX_PASSWORD>
RTX_PASS=<RTX_PASSWORD>
RTX_REMOTE_DIR=/data/robot_project/inference_server
